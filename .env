APP_NAME=SAGS - MVIIS S2D Online Programmer 
HOST=0.0.0.0
PORT=80
DEBUG=false

# ── Programs storage path per platform ──────────────────────────────────────
# config.py auto-detects the OS and picks the matching variable.
# Override PROGRAMS_DIR directly to bypass auto-detection.

# Linux
LINUX_PROGRAMS_DIR=/home/mviis

# Windows
WIN_PROGRAMS_DIR=C:\Users\Melvin Venceslass\APP_ENV\programs

# macOS  (leave empty to use the app default: <project_dir>/programs)
MAC_PROGRAMS_DIR=/Users/meltina/Documents/Business/Projects/Sanmina/app_env/programs

# ── Log paths per platform ───────────────────────────────────────────────────
# Conduit log directory
LINUX_CONDUIT_LOG_PATH=/home/mviis/logs/conduit
WIN_CONDUIT_LOG_PATH=C:\Users\Melvin Venceslass\APP_ENV\logs\conduit
MAC_CONDUIT_LOG_PATH=/Users/meltina/Documents/Business/Projects/Sanmina/app_env/conduit_log

# Assembly log directory
LINUX_ASSEMBLY_LOG_PATH=/home/mviis/logs/assy
WIN_ASSEMBLY_LOG_PATH=C:\Users\Melvin Venceslass\APP_ENV\logs\assy
MAC_ASSEMBLY_LOG_PATH=/Users/meltina/Documents/Business/Projects/Sanmina/app_env/assy_log

# System log directory
LINUX_SYSTEM_LOG_PATH=/home/mviis/logs/system
WIN_SYSTEM_LOG_PATH=C:\Users\Melvin Venceslass\APP_ENV\logs\system
MAC_SYSTEM_LOG_PATH=/Users/meltina/Documents/Business/Projects/Sanmina/app_env/logs/log

# ── MES Configuration (JSON string) ─────────────────────────────────────────
LINUX_MES_CONFIG=/home/mviis/logs/system
WIN_MES_CONFIG=C:\Users\Melvin Venceslass\APP_ENV\logs\system
MAC_MES_CONFIG=/Users/meltina/Documents/Business/Projects/Sanmina/app_env/mes_config.json