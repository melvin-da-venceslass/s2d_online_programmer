APP_NAME=Program Editor
HOST=0.0.0.0
PORT=80
DEBUG=false

# ── Programs storage path per platform ──────────────────────────────────────
# config.py auto-detects the OS and picks the matching variable.
# Override PROGRAMS_DIR directly to bypass auto-detection.

# Linux
LINUX_PROGRAMS_DIR=/home/mviis/programs

# Windows
WIN_PROGRAMS_DIR=C:\Users\Melvin Venceslass\APP_ENV\programs

# macOS  (leave empty to use the app default: <project_dir>/programs)
MAC_PROGRAMS_DIR=
